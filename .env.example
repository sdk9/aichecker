# ── Required ──────────────────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your-secret-key-here

# ── URLs ──────────────────────────────────────────────────────────────────────
# Public URL of your VPS/domain (used in reset emails and Stripe redirects)
FRONTEND_URL=http://2.24.28.22:3000
CORS_ORIGINS=http://2.24.28.22:3000,http://localhost:5173
# Set to your VPS backend URL so the frontend can reach it
VITE_API_URL=http://2.24.28.22:8000

# ── Stripe (required for payments) ────────────────────────────────────────────
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_...
# Get from: https://dashboard.stripe.com/webhooks  (after adding webhook for /api/billing/webhook)
STRIPE_WEBHOOK_SECRET=whsec_...
# Create prices at: https://dashboard.stripe.com/products
STRIPE_PRO_PRICE_ID=price_...
STRIPE_ENTERPRISE_PRICE_ID=price_...

# ── Email / SMTP (optional — reset tokens log to console if not set) ──────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=VeritasAI <noreply@veritasai.app>
